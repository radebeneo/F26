# ============================================================
# FIFA World Cup 2026 Fantasy – Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ============================================================

# ----- Supabase (public – safe to expose to the browser) -----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ----- Supabase (server-only – NEVER expose client-side) -----
SUPABASE_SERVICE_ROLE_KEY=

# ----- Drizzle ORM connection string -----
# Format: postgresql://[user]:[password]@[host]:[port]/[dbname]?sslmode=require
# Find this in: Supabase → Settings → Database → Connection string → URI (Transaction mode port 6543)
DATABASE_URL=

# ----- Admin API secret -----
# Bearer token for POST /api/admin/stats
# Generate with: openssl rand -hex 32
ADMIN_API_SECRET=
